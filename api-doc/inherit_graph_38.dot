digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  rankdir="LR";
  Node0 [label="YEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYEvent.html",tooltip=" "];
  Node0 -> Node1 [dir="back",color="steelblue1",style="solid"];
  Node1 [label="YCancelEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYCancelEvent.html",tooltip=" "];
  Node0 -> Node2 [dir="back",color="steelblue1",style="solid"];
  Node2 [label="YDebugEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYDebugEvent.html",tooltip=" "];
  Node0 -> Node3 [dir="back",color="steelblue1",style="solid"];
  Node3 [label="YKeyEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYKeyEvent.html",tooltip=" "];
  Node0 -> Node4 [dir="back",color="steelblue1",style="solid"];
  Node4 [label="YMenuEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYMenuEvent.html",tooltip=" "];
  Node0 -> Node5 [dir="back",color="steelblue1",style="solid"];
  Node5 [label="YSpecialKeyEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYSpecialKeyEvent.html",tooltip=" "];
  Node0 -> Node6 [dir="back",color="steelblue1",style="solid"];
  Node6 [label="YTimeoutEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYTimeoutEvent.html",tooltip=" "];
  Node0 -> Node7 [dir="back",color="steelblue1",style="solid"];
  Node7 [label="YWidgetEvent",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYWidgetEvent.html",tooltip=" "];
}
