digraph "YApplicationPrivate"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [label="YApplicationPrivate",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip=" "];
  Node2 -> Node1 [dir="back",color="darkorchid3",style="dashed",label=" applicationIcon\napplicationTitle\nproductName" ];
  Node2 [label="string",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node3 -> Node1 [dir="back",color="darkorchid3",style="dashed",label=" defaultFunctionKey" ];
  Node3 [label="map\< string, int \>",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node4 -> Node1 [dir="back",color="darkorchid3",style="dashed",label=" iconLoader" ];
  Node4 [label="YIconLoader",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",URL="$classYIconLoader.html",tooltip=" "];
  Node5 -> Node1 [dir="back",color="darkorchid3",style="dashed",label=" releaseNotes" ];
  Node5 [label="map\< string, string \>",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
}
