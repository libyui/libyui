digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  rankdir="LR";
  Node0 [label="YItem",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYItem.html",tooltip=" "];
  Node0 -> Node1 [dir="back",color="steelblue1",style="solid"];
  Node1 [label="YDescribedItem",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYDescribedItem.html",tooltip=" "];
  Node0 -> Node2 [dir="back",color="steelblue1",style="solid"];
  Node2 [label="YTreeItem",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYTreeItem.html",tooltip=" "];
  Node2 -> Node3 [dir="back",color="steelblue1",style="solid"];
  Node3 [label="YMenuItem",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYMenuItem.html",tooltip=" "];
  Node2 -> Node4 [dir="back",color="steelblue1",style="solid"];
  Node4 [label="YTableItem",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYTableItem.html",tooltip=" "];
  Node2 -> Node5 [dir="back",color="steelblue1",style="solid"];
  Node5 [label="YWidgetTreeItem",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classYWidgetTreeItem.html",tooltip=" "];
}
