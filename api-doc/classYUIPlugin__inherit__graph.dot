digraph "YUIPlugin"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [label="YUIPlugin",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip=" "];
  Node1 -> Node2 [dir="back",color="steelblue1",style="solid"];
  Node2 [label="YGraphPlugin",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$classYGraphPlugin.html",tooltip=" "];
  Node1 -> Node3 [dir="back",color="steelblue1",style="solid"];
  Node3 [label="YPackageSelectorPlugin",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$classYPackageSelectorPlugin.html",tooltip=" "];
}
